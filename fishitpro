    if not PlayerGui then return false end
    
    -- Cari semua TextLabel yang visible
    for _, gui in pairs(PlayerGui:GetDescendants()) do
        if gui:IsA("TextLabel") and gui.Visible then
            local text = gui.Text:lower()
            if text:find("!") or text:find("bite") or text:find("fish") or text:find("pull") then
                -- Verifikasi posisi (biasanya di tengah layar)
                local pos = gui.AbsolutePosition
                local size = gui.AbsoluteSize
                local centerX = pos.X + size.X/2
                local centerY = pos.Y + size.Y/2
                
                -- Cek kalau di area yang masuk akal
                if centerY < 400 and centerY > 100 then  -- Upper middle area
                    return true, gui
                end
            end
        end
        
        -- Cek ImageLabel (ikon seru/exclamation)
        if gui:IsA("ImageLabel") and gui.Visible and gui.Image ~= "" then
            if gui.Name:lower():find("alert") or gui.Name:lower():find("bite") or gui.Name:lower():find("exclamation") then
                return true, gui
            end
        end
    end
    
    -- Method 2: Cek perubahan di area indikator (gunakan cache)
    -- (Ini butuh screenshot comparison, complex di Roblox)
    
    return false
end

