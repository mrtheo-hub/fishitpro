-- Humanized Click (BAC tidak bisa bedain dari human)
function SilentFish:HumanClick(x, y, duration)
    duration = duration or math.random(
        math.floor(self.Config.MinDelay * 1000), 
        math.floor(self.Config.MaxDelay * 1000)
    ) / 1000
    
    -- Pre-movement (realistic)
    VirtualInputManager:SendMouseMoveEvent(x + math.random(-5, 5), y + math.random(-5, 5), game)
    task.wait(math.random(0.05, 0.12))
    
    -- Click down
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, true, game, 0)
    task.wait(duration)
    
    -- Click up
    VirtualInputManager:SendMouseButtonEvent(x, y, 0, false, game, 0)
    
    -- Post-movement
    task.wait(math.random(0.03, 0.08))
    
    self.State.ConsecutiveClicks += 1
    
    -- Random pause setiap 10-20 click (human fatigue)
    if self.State.ConsecutiveClicks > math.random(10, 20) then
        task.wait(math.random(0.3, 0.8))
        self.State.ConsecutiveClicks = 0
    end
end

-- Visual Detection (BAC gak bisa detect ini)
function SilentFish:DetectBiteVisual()
    -- Method 1: Cek UI Text "!" atau "BITE"
    local PlayerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not PlayerGui then return false end
    
    -- Cari semua TextLabel yang visible
    for _, gui in pairs(PlayerGui:GetDescendants()) do
        if gui:IsA("TextLabel") and gui.Visible then
            local text = gui.Text:lower()
            if text:find("!") or text:find("bite") or text:find("fish") or text:find("pull") then
                -- Verifikasi posisi (biasanya di tengah layar)
                local pos = gui.AbsolutePosition
                local size = gui.AbsoluteSize
                local centerX = pos.X + size.X/2
                local centerY = pos.Y + size.Y/2
                
                -- Cek kalau di area yang masuk akal
                if centerY < 400 and centerY > 100 then  -- Upper middle area
                    return true, gui
                end
            end
        end
        
        -- Cek ImageLabel (ikon seru/exclamation)
        if gui:IsA("ImageLabel") and gui.Visible and gui.Image ~= "" then
            if gui.Name:lower():find("alert") or gui.Name:lower():find("bite") or gui.Name:lower():find("exclamation") then
                return true, gui
            end
        end
    end
    
    -- Method 2: Cek perubahan di area indikator (gunakan cache)
    -- (Ini butuh screenshot comparison, complex di Roblox)
    
    return false
end

-- Audio Detection (kalau game ada suara bite)
function SilentFish:DetectBiteAudio()
    -- Roblox limit audio access dari client script
    -- Tapi bisa detect Sound instances yang play
    for _, sound in pairs(workspace:GetDescendants()) do
