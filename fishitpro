-- Simulate click by changing properties (Ronix hack)
function Fish:ClickButton(button)
    if not button then return end
    
    -- Method 1: Change visual state (might trigger events)
    local original = button.BackgroundColor3
    button.BackgroundColor3 = Color3.new(0.5, 0.5, 0.5)
    
    -- Method 2: Toggle Active
    local wasActive = button.Active
    button.Active = false
    task.wait(0.05)
    button.Active = true
    button.Active = wasActive
    
    -- Method 3: Simulate selection
    if button.Selectable then
        button:Select()
    end
    
    -- Restore visual
    task.wait(0.1)
    button.BackgroundColor3 = original
end

-- Main loop
function Fish:Loop()
    while self.Config.Enabled do
        -- Cast
        if not self.State.Running then
            print("Casting...")
            self:ClickButton(self.State.CastButton)
            self.State.Running = true
            task.wait(2)
        end
        
        -- Wait for bite
        local waitStart = tick()
        local gotBite = false
        
        while tick() - waitStart < 10 do
            if self:IsBiting() then
                gotBite = true
                print("Bite detected!")
                task.wait(0.3)  -- Reaction time
                break
            end
            task.wait(0.1)
        end
        
        -- Reel
        if gotBite then
            local reelStart = tick()
            
            while tick() - reelStart < 5 do
                self:ClickButton(self.State.ReelButton)
                
                task.wait(0.5)
                if not self:IsBiting() then
                    break
                end
                
                task.wait(self.Config.Delay)
            end
            
            print("Caught!")
            self.State.Running = false
            task.wait(1)
        else
            print("Timeout")
            self.State.Running = false
            task.wait(1)
        end
    end
end

