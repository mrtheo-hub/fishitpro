-- Touch Simulation (Mobile optimized)
function MobileFish:Touch(x, y, duration)
    duration = duration or math.random(
        self:GetDelay().Min * 100, 
        self:GetDelay().Max * 100
    ) / 100
    
    -- Pre-touch wobble (finger adjustment)
    local wobbleX = x + math.random(-10, 10)
    local wobbleY = y + math.random(-10, 10)
    
    -- Touch down
    VirtualInputManager:SendTouchEvent(wobbleX, wobbleY, 0, true, game, 0)
    task.wait(duration)
    
    -- Touch up
    VirtualInputManager:SendTouchEvent(wobbleX, wobbleY, 0, false, game, 0)
    
    -- Recovery delay
    task.wait(math.random(50, 150) / 1000)
end

-- Multi-touch reel (mobile trick: multiple fingers)
