-- Baca UI Game (100% aman, hanya read property)
function AssistFish:ScanUI()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return nil end
    
    local ui = {
        CastButton = nil,
        ReelButton = nil,
        BiteText = nil,
        BiteImage = nil,
        ProgressBar = nil,
        FishCounter = nil,
    }
    
    for _, gui in pairs(playerGui:GetDescendants()) do
        -- Cari berdasarkan nama pattern
        local name = gui.Name:lower()
        
        -- Cast button
        if gui:IsA("TextButton") or gui:IsA("ImageButton") then
            if name:find("cast") or name:find("throw") or name:find("fish") then
                ui.CastButton = gui
            elseif name:find("reel") or name:find("pull") or name:find("tap") then
                ui.ReelButton = gui
            end
        end
        
        -- Bite indicator
        if gui:IsA("TextLabel") then
            if name:find("bite") or name:find("alert") or namefind("bite") or name:find("alert") or name:find("exclaim") or name:find("!") then
                ui.BiteText = gui
            end
            -- Cari juga berdasarkan text content
            if gui.Text and (gui.Text:find("!") or gui.Text:lower():find("bite")) then
                ui.BiteText = gui
            end
        end
        
        if gui:IsA("ImageLabel") then
            if name:find("bite") or name:find("alert") or name:find("exclaim") then
                ui.BiteImage = gui
            end
        end
        
        -- Progress bar (biasanya ada saat reel)
        if gui:IsA("Frame") and gui.Name:lower():find("progress") then
            ui.ProgressBar = gui
        end
    end
    
    return ui
end

-- Detect bite (pure read, no function calls)
function AssistFish:CheckBite(ui)
    if not ui then return false end
    
    -- Check text label
    if ui.BiteText then
        if ui.BiteText.Visible and ui.BiteText.Text ~= "" then
            return true, "text"
        end
    end
    
    -- Check image
    if ui.BiteImage then
        if ui.BiteImage.Visible then
            return true, "image"
        end
    end
    
    -- Check progress bar muncul (indikasi reel time)
    if ui.ProgressBar then
        if ui.ProgressBar.Visible and ui.ProgressBar.Size.X.Scale > 0 then
            return true, "progress"
        end
    end
    
    -- Check perubahan text di UI lain
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        for _, gui in pairs(playerGui:GetDescendants()) do
            if gui:IsA("TextLabel") and gui.Visible then
                local text = gui.Text
                if text and (#text > 0) then
                    local lower = text:lower()
                    if lower:find("!") or lower:find("now") or lower:find("pull") or lower:find("bite") then
                        -- Pastikan ini bukan text yang selama ada
                        if not self.StaticTexts then
                            self.StaticTexts = {}
                            -- Scan sekali untuk catat text yang selama ada
                            for _, g in pairs(playerGui:GetDescendants()) do
                                if g:IsA("TextLabel") then
                                    self.StaticTexts[g] = g.Text
                                end
                            end
                        end
                        
                        -- Kalau text berubah dari awal, itu bite!
                        if self.StaticTexts[gui] ~= text then
                            return true, "text_change"
                        end
                    end
                end
            end
        end
    end
    
    return false
end

-- Visual/Sound Alert (tidak inject, hanya UI)
