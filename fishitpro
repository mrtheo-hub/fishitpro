        if sound:IsA("Sound") and sound.Playing then
            local name = sound.Name:lower()
            if name:find("bite") or name:find("splash") or name:find("alert") then
                return true
            end
        end
    end
    return false
end

-- Check Safety Limits
function SilentFish:CheckSafety()
    local now = tick()
    local runtime = now - self.State.StartTime
    local fishRate = self.State.FishCount / (runtime / 3600)  -- per hour
    
    -- Check max fish per hour
    if fishRate > self.Config.MaxFishPerHour then
        print("⚠️ Rate limit reached, taking break...")
        task.wait(math.random(60, 120))
        self.State.StartTime = now
        self.State.FishCount = 0
    end
    
    -- Check break interval
    if now - self.State.LastBreak > self.Config.BreakInterval then
        print("☕ Taking scheduled break...")
        task.wait(self.Config.BreakDuration)
        self.State.LastBreak = now
    end
    
    return true
end

-- Main Fishing Logic
function SilentFish:FishingLoop()
    while self.Config.Enabled do
        if not self:CheckSafety() then
            task.wait(1)
            continue
        end
        
        -- Step 1: Cast (kalau belum fishing)
        if not self.State.IsFishing then
            local castPos = self:GetScreenPos(self.Config.CastButton.X, self.Config.CastButton.Y)
            self:HumanClick(castPos.X, castPos.Y, 0.1)
            self.State.IsFishing = true
            task.wait(1.5 + math.random(0.5, 1.0))  -- Tunggu kail turun
        end
        
        -- Step 2: Wait for bite dengan reaction time human-like
        local biteDetected = false
        local waitStart = tick()
        
        while tick() - waitStart < 15 do  -- Max wait 15 detik
            if self:DetectBiteVisual() or self:DetectBiteAudio() then
                -- Human reaction delay
                task.wait(math.random(
                    self.Config.ReactionMin * 100, 
                    self.Config.ReactionMax * 100
                ) / 100)
                biteDetected = true
                break
            end
            task.wait(0.05)  -- Poll rate
        end
        
        -- Step 3: Reel
        if biteDetected then
            print("🐟 Fish on! Reeling...")
            
            -- Reel dengan pola human-like (bukan spam flat)
            local reelStart = tick()
            local reelDuration = math.random(2, 4)
            
            while tick() - reelStart < reelDuration do
                -- Random position dalam area reel
                local reelX = math.random(
                    self.Config.ReelArea.X1 * 100, 
                    self.Config.ReelArea.X2 * 100
                ) / 100
                local reelY = math.random(
                    self.Config.ReelArea.Y1 * 100, 
                    self.Config.ReelArea.Y2 * 100
                ) / 100
                
                local pos = self:GetScreenPos(reelX, reelY)
                self:HumanClick(pos.X, pos.Y)
                
                -- Cek kalau masih biting
                if not self:DetectBiteVisual() and not self:DetectBiteAudio() then
                    task.wait(0.5)
                    if not self:DetectBiteVisual() then
                        break  -- Fish caught or escaped
                    end
                end
            end
            
            self.State.FishCount += 1
            self.State.IsFishing = false
            task.wait(math.random(0.8, 1.5))  -- Cooldown sebelum cast ulang
            
        else
            -- Timeout, cast ulang
            self.State.IsFishing = false
        end
        
        task.wait(0.1)
    end
end

function SilentFish:Start()
    print("🎣 Silent Fish Started")
    print("Mode:", self.Config.Mode)
    print("Safety: Max", self.Config.MaxFishPerHour, "fish/hour")
    
    self.State.StartTime = tick()
    self.State.LastBreak = tick()
    
    task.spawn(function()
        self:FishingLoop()
    end)
end

function SilentFish:Stop()
    self.Config.Enabled = false
    self.State.IsFishing = false
    print("⏹️ Stopped")
end

-- Initialize
SilentFish:CreateSilentGUI()

return SilentFish
