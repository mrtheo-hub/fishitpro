-- Cari ClickDetectors di workspace (untuk Cast)
function RonixFish:FindCastDetector()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") then
            local name = obj.Parent.Name:lower()
            if name:find("cast") or name:find("rod") or name:find("fish") then
                print("Found Cast:", obj.Parent.Name)
                return obj
            end
        end
    end
    return nil
end

-- Cari TouchInterest untuk reel (kalau ada)
function RonixFish:FindReelTouch()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("TouchTransmitter") or obj:IsA("TouchInterest") then
            local parent = obj.Parent
            if parent and (parent.Name:lower():find("reel") or parent.Name:lower():find("water")) then
                return parent
            end
        end
    end
    return nil
end

-- Cari ProximityPrompt (alternative)
function RonixFish:FindPrompts()
    local cast = nil
    local reel = nil
    
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local name = obj.ActionText:lower()
            if name:find("cast") or name:find("fish") then
                cast = obj
                print("Found Prompt Cast:", obj.ActionText)
            elseif name:find("reel") or name:find("pull") then
                reel = obj
                print("Found Prompt Reel:", obj.ActionText)
            end
        end
    end
    
    return cast, reel
end

-- Cari RemoteEvents (last resort - risky!)
function RonixFish:FindRemotes()
    local cast = nil
    local reel = nil
    local catch = nil
    
    for _, obj in pairs(game:GetDescendants()) do
        if obj:IsA("RemoteEvent") then
            local name = obj.Name:lower()
            if name:find("cast") or name:find("throw") then
                cast = obj
            elseif name:find("reel") or name:find("pull") then
                reel = obj
            elseif name:find("catch") or name:find("collect") then
                catch = obj
            end
        end
    end
    
    return cast, reel, catch
end

-- Detect bite via UI
function RonixFish:DetectBite()
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return false end
    
    for _, gui in pairs(playerGui:GetDescendants()) do
        if gui:IsA("TextLabel") and gui.Visible then
            local text = gui.Text:lower()
            if text:find("!") or text:find("bite") or text:find("now") or text:find("pull") then
                return true
            end
        end
        if gui:IsA("ImageLabel") and gui.Visible then
            local name = gui.Name:lower()
            if name:find("alert") or name:find("exclaim") or name:find("bite") then
                return true
            end
        end
    end
    
    return false
end

-- Main method: FireClickDetector
function RonixFish:DoCast()
    if self.State.CastCD then
        -- Ronix method
        pcall(function()
            fireclickdetector(self.State.CastCD)
        end)
        return true
    end
    
    -- Try ProximityPrompt
    local castPrompt = self.State.CastPrompt
    if castPrompt then
        pcall(function()
            fireproximityprompt(castPrompt)
        end)
        return true
    end
    
    -- Try Remote (last resort)
    if self.State.CastRemote then
        pcall(function()
            self.State.CastRemote:FireServer()
        end)
        return true
    end
    
    return false
end

function RonixFish:DoReel()
    -- Try TouchInterest
    if self.State.ReelTouch then
        pcall(function()
            firetouchinterest(LocalPlayer.Character.HumanoidRootPart, self.State.ReelTouch, 0)
            task.wait(0.1)
            firetouchinterest(LocalPlayer.Character.HumanoidRootPart, self.State.ReelTouch, 1)
        end)
        return true
    end
    
    -- Try ProximityPrompt
    if self.State.ReelPrompt then
        pcall(function()
            fireproximityprompt(self.State.ReelPrompt)
        end)
        return true
    end
    
    -- Try Remote
    if self.State.ReelRemote then
        pcall(function()
            self.State.ReelRemote:FireServer()
        end)
        return true
    end
    
    return false
end

-- Initialize scanning
function RonixFish:Init()
    print("🔍 Scanning game...")
    
    -- Method 1: ClickDetectors
    self.State.CastCD = self:FindCastDetector()
    
    -- Method 2: TouchInterests
    self.State.ReelTouch = self:FindReelTouch()
    
    -- Method 3: ProximityPrompts
    local castP, reelP = self:FindPrompts()
    self.State.CastPrompt = castP
    self.State.ReelPrompt = reelP
    
    -- Method 4: Remotes (risky tapi backup)
    local castR, reelR, catchR = self:FindRemotes()
    self.State.CastRemote = castR
    self.State.ReelRemote = reelR
    self.State.CatchRemote = catchR
    
    -- Summary
    print("=== SCAN RESULT ===")
    print("Cast ClickDetector:", self.State.CastCD and "YES" or "NO")
    print("Cast Prompt:", castP and "YES" or "NO")
    print("Cast Remote:", castR and "YES" or "NO")
    print("Reel Touch:", self.State.ReelTouch and "YES" or "NO")
    print("Reel Prompt:", reelP and "YES" or "NO")
    print("Reel Remote:", reelR and "YES" or "NO")
    print("==================")
    
    return (self.State.CastCD or castP or castR) and (reelP or reelR or self.State.ReelTouch)
end

-- Random wait
function RonixFish:Wait(min, max)
    max = max or min * 1.5
    task.wait(min + math.random() * (max - min))
end

-- Main loop
function RonixFish:Loop()
    local delays = self.Config.Delays[self.Config.Mode]
    
    while self.Config.Enabled do
        -- Check limits
        if self.State.FishCount >= self.Config.Limits.MaxFish then
            print("🛑 Max fish reached")
            break
        end
        
        local elapsed = (tick() - self.State.StartTime) / 60
        if elapsed >= self.Config.Limits.MaxTime then
            print("🛑 Time limit")
            break
        end
        
        -- Break
        if self.State.FishCount > 0 and self.State.FishCount % self.Config.Limits.BreakEvery == 0 then
            print("☕ Break time")
            task.wait(self.Config.Limits.BreakTime)
        end
        
        -- Cast
        if not self.State.Fishing then
            print("🎣 Casting...")
            self:DoCast()
            self.State.Fishing = true
            self:Wait(delays.Cast)
        end
        
        -- Wait bite
        local biteStart = tick()
        local gotBite = false
        
        while (tick() - biteStart) < 10 do
            if self:DetectBite() then
                self:Wait(delays.Reaction)
                gotBite = true
                print("🐟 Bite!")
                break
            end
            task.wait(0.1)
        end
        
        -- Reel
        if gotBite then
            local reelStart = tick()
            
            while (tick() - reelStart) < 6 do
                self:DoReel()
                
                -- Check still biting
                task.wait(0.4)
                if not self:DetectBite() then
                    task.wait(0.3)
                    if not self:DetectBite() then
                        print("✓ Caught!")
                        break
                    end
                end
                
                self:Wait(delays.Reel)
            end
            
            self.State.FishCount = self.State.FishCount + 1
            self.State.Fishing = false
            self:Wait(delays.Between)
            
        else
            print("⚠ Timeout")
            self.State.Fishing = false
            task.wait(2)
        end
    end
    
    self:Stop()
end

