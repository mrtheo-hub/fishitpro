-- Detection Methods
function MobileFish:DetectBite()
    local detected = false
    local method = ""
    
    -- Method 1: Visual (UI)
    if self.Config.Detection.UseVisual then
        local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
        if playerGui then
            for _, gui in pairs(playerGui:GetDescendants()) do
                if gui:IsA("TextLabel") and gui.Visible then
                    local text = gui.Text:lower()
                    if text:find("!") or text:find("bite") or text:find("pull") or text:find("now") then
                        -- Verify position (biasanya atas)
                        local pos = gui.AbsolutePosition.Y
                        if pos < 300 then
                            detected = true
                            method = "Visual"
                            break
                        end
                    end
                end
                
                if gui:IsA("ImageLabel") and gui.Visible then
                    local name = gui.Name:lower()
                    if name:find("alert") or name:find("exclamation") or name:find("bite") then
                        detected = true
                        method = "VisualIcon"
                        break
                    end
                end
            end
        end
    end
    
    -- Method 2: Audio (Sound playing)
    if not detected and self.Config.Detection.UseAudio then
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("Sound") and obj.Playing then
                local name = obj.Name:lower()
                if name:find("splash") or name:find("bite") or name:find("alert") then
                    detected = true
                    method = "Audio"
                    break
                end
            end
        end
    end
    
    return detected, method
end

