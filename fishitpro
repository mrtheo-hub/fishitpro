-- Find Remotes Function
function FishItPro:FindRemotes()
    for _, v in pairs(ReplicatedStorage:GetDescendants()) do
        if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
            local name = v.Name:lower()
            if name:find("cast") or name:find("throw") then
                Remotes.Cast = v
            elseif name:find("reel") or name:find("pull") or name:find("tug") then
                Remotes.Reel = v
            elseif name:find("catch") or name:find("collect") or name:find("harvest") then
                Remotes.Catch = v
            elseif name:find("sell") then
                Remotes.Sell = v
            elseif name:find("equip") then
                Remotes.Equip = v
            end
        end
    end
    
    -- Cari di workspace juga
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("RemoteEvent") and v.Name:lower():find("fish") then
            if not Remotes.Catch then Remotes.Catch = v end
        end
    end
end

