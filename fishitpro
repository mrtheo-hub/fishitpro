    Enabled = false,
    AutoReel = false, -- Kalau true, coba pakai metode yang tersedia
    
    -- Timing
    CastDelay = 2.5,      -- Detik setelah cast sebelum mulai detect
    ReactionDelay = 0.3,  -- Delay setelah detect bite sebelum reel
    
    -- Safety
    BeepOnBite = true,    -- Suara/notifikasi visual
    AutoStopAfter = 50,   -- Stop setelah X fish
}

