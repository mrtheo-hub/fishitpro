-- Animation Utility (Manual Lerp, tidak pakai TweenService berat)
function PremiumFish:Animate(object, property, target, duration)
    duration = duration or 0.3
    local start = object[property]
    local startTime = tick()
    
    task.spawn(function()
        while tick() - startTime < duration do
            local alpha = (tick() - startTime) / duration
            -- Ease out quad
            alpha = 1 - (1 - alpha) * (1 - alpha)
            
            if property == "Size" then
                object.Size = UDim2.new(
                    start.X.Scale + (target.X.Scale - start.X.Scale) * alpha,
                    start.X.Offset + (target.X.Offset - start.X.Offset) * alpha,
                    start.Y.Scale + (target.Y.Scale - start.Y.Scale) * alpha,
                    start.Y.Offset + (target.Y.Offset - start.Y.Offset) * alpha
                )
            elseif property == "Position" then
                object.Position = UDim2.new(
                    start.X.Scale + (target.X.Scale - start.X.Scale) * alpha,
                    start.X.Offset + (target.X.Offset - start.X.Offset) * alpha,
                    start.Y.Scale + (target.Y.Scale - start.Y.Scale) * alpha,
                    start.Y.Offset + (target.Y.Offset - start.Y.Offset) * alpha
                )
            elseif property == "BackgroundColor3" then
                object.BackgroundColor3 = Color3.new(
                    start.R + (target.R - start.R) * alpha,
                    start.G + (target.G - start.G) * alpha,
                    start.B + (target.B - start.B) * alpha
                )
            elseif property == "TextColor3" then
                object.TextColor3 = Color3.new(
                    start.R + (target.R - start.R) * alpha,
                    start.G + (target.G - start.G) * alpha,
                    start.B + (target.B - start.B) * alpha
                )
            elseif property == "BackgroundTransparency" then
                object.BackgroundTransparency = start + (target - start) * alpha
            elseif property == "TextTransparency" then
                object.TextTransparency = start + (target - start) * alpha
            elseif property == "Rotation" then
                object.Rotation = start + (target - start) * alpha
            end
            
            task.wait(0.016) -- ~60fps
        end
        
        -- Set final value
        object[property] = target
    end)
end

-- Pulse Animation (Button breathing effect)
function PremiumFish:PulseAnimation(button, baseColor, pulseColor)
    task.spawn(function()
        while button and button.Parent do
            if not self.Config.Enabled then
                -- Pulse slow when idle
                for i = 0, 100, 2 do
                    if not button.Parent then return end
                    local alpha = math.sin(i / 100 * math.pi)
                    button.BackgroundColor3 = baseColor:Lerp(pulseColor, alpha * 0.3)
                    task.wait(0.05)
                end
            else
                -- Pulse fast when active
                for i = 0, 100, 5 do
                    if not button.Parent then return end
                    local alpha = math.sin(i / 100 * math.pi)
                    button.BackgroundColor3 = baseColor:Lerp(self.Config.Theme.Accent, alpha * 0.5)
                    task.wait(0.02)
                end
            end
        end
    end)
end

-- Particle Effect (Simple dots)
function PremiumFish:CreateParticles(parent, color)
    task.spawn(function()
        while parent and parent.Parent and self.Config.Enabled do
            local particle = Instance.new("Frame")
            particle.Size = UDim2.new(0, math.random(4, 8), 0, math.random(4, 8))
            particle.Position = UDim2.new(math.random(), 0, 1, 0)
            particle.BackgroundColor3 = color
            particle.BorderSizePixel = 0
            particle.Parent = parent
            
            Instance.new("UICorner", particle).CornerRadius = UDim.new(1, 0)
            
            -- Animate up
            task.spawn(function()
                for i = 1, 50 do
                    if not particle.Parent then return end
                    particle.Position = UDim2.new(
                        particle.Position.X.Scale,
                        0,
                        particle.Position.Y.Scale - 0.02,
                        0
                    )
                    particle.BackgroundTransparency = i / 50
                    task.wait(0.03)
                end
                particle:Destroy()
            end)
            
            task.wait(0.2)
        end
    end)
end

-- Ripple Effect (Click feedback)
function PremiumFish:Ripple(button, x, y)
    local ripple = Instance.new("Frame")
    ripple.Size = UDim2.new(0, 0, 0, 0)
    ripple.Position = UDim2.new(0, x - button.AbsolutePosition.X, 0, y - button.AbsolutePosition.Y)
    ripple.BackgroundColor3 = Color3.new(1, 1, 1)
    ripple.BackgroundTransparency = 0.7
    ripple.BorderSizePixel = 0
    ripple.ZIndex = 10
    ripple.Parent = button
    
    Instance.new("UICorner", ripple).CornerRadius = UDim.new(1, 0)
    
    -- Expand and fade
    task.spawn(function()
        for i = 1, 30 do
            if not ripple.Parent then return end
            local size = i * 10
            ripple.Size = UDim2.new(0, size, 0, size)
            ripple.Position = UDim2.new(0, x - button.AbsolutePosition.X - size/2, 0, y - button.AbsolutePosition.Y - size/2)
            ripple.BackgroundTransparency = 0.7 + (i / 30) * 0.3
            task.wait(0.016)
        end
        ripple:Destroy()
    end)
end

-- Shake Animation (Error/Warning)
function PremiumFish:Shake(object)
    task.spawn(function()
        local original = object.Position
        for i = 1, 10 do
            if not object.Parent then return end
            local offset = math.sin(i) * 5
            object.Position = UDim2.new(
                original.X.Scale,
                original.X.Offset + offset,
                original.Y.Scale,
                original.Y.Offset
            )
            task.wait(0.03)
        end
        object.Position = original
    end)
end

-- Count Up Animation (Stats)
function PremiumFish:CountUp(label, target, suffix)
    task.spawn(function()
        local current = 0
        local step = math.ceil(target / 20)
        
        while current < target do
            if not label.Parent then return end
            current = math.min(current + step, target)
            label.Text = tostring(current) .. (suffix or "")
            task.wait(0.05)
        end
    end)
end

-- Gradient Effect (Simulated with multiple frames)
function PremiumFish:CreateGradient(parent, color1, color2, direction)
    local gradient = Instance.new("Frame")
    gradient.Size = UDim2.new(1, 0, 1, 0)
    gradient.BackgroundTransparency = 1
    gradient.BorderSizePixel = 0
    gradient.Parent = parent
    
    local steps = 10
    for i = 1, steps do
        local bar = Instance.new("Frame")
        bar.Size = UDim2.new(1 / steps, 0, 1, 0)
        bar.Position = UDim2.new((i - 1) / steps, 0, 0, 0)
        bar.BorderSizePixel = 0
        
        local alpha = (i - 1) / (steps - 1)
        bar.BackgroundColor3 = color1:Lerp(color2, alpha)
        bar.Parent = gradient
    end
    
    return gradient
end

-- Glow Effect (Shadow simulation)
function PremiumFish:CreateGlow(parent, color, intensity)
    local glow = Instance.new("Frame")
    glow.Name = "Glow"
    glow.Size = UDim2.new(1, 20, 1, 20)
    glow.Position = UDim2.new(0, -10, 0, -10)
    glow.BackgroundColor3 = color
    glow.BackgroundTransparency = 1 - intensity
    glow.BorderSizePixel = 0
    glow.ZIndex = -1
    glow.Parent = parent
    
    Instance.new("UICorner", glow).CornerRadius = UDim.new(0, 20)
    
    -- Pulse glow
    task.spawn(function()
        while glow.Parent do
            for i = 0, 100, 2 do
                if not glow.Parent then return end
                local alpha = 0.5 + math.sin(i / 100 * math.pi * 2) * 0.3
                glow.BackgroundTransparency = 1 - (intensity * alpha)
                task.wait(0.03)
            end
        end
    end)
    
    return glow
end

