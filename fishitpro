-- CRITICAL: Mobile Touch Simulation (BUKAN VirtualInputManager!)
function MobileFish:Touch(x, y, holdMs)
    holdMs = holdMs or math.random(self.Config.HoldMin, self.Config.HoldMax)
    
    -- Jitter position (anti-pattern)
    local jitterX = math.random(-self.Config.TouchJitter, self.Config.TouchJitter)
    local jitterY = math.random(-self.Config.TouchJitter, self.Config.TouchJitter)
    local finalX = math.floor(x + jitterX)
    local finalY = math.floor(y + jitterY)
    
    -- Clamp ke screen bounds
    local screen = workspace.CurrentCamera.ViewportSize
    finalX = math.clamp(finalX, 10, screen.X - 10)
    finalY = math.clamp(finalY, 10, screen.Y - 10)
    
    -- Simulate touch using UserInputService (mobile native)
    local touchInput = {
        Position = Vector2.new(finalX, finalY),
        Delta = Vector2.zero,
        State = Enum.UserInputState.Begin
    }
    
    -- Fire touch began
    pcall(function()
        -- Method 1: Simulate dengan InputBegan event (lebih stealth)
        local inputObject = {
            UserInputType = Enum.UserInputType.Touch,
            Position = Vector2.new(finalX, finalY),
            State = Enum.UserInputState.Begin
        }
        
        -- Trigger pada game UI (bypass BAC dengan native touch)
        self:FireTouchToUI(finalX, finalY, true)
    end)
    
    -- Hold duration
    task.wait(holdMs / 1000)
    
    -- Fire touch ended
    pcall(function()
        self:FireTouchToUI(finalX, finalY, false)
    end)
    
    -- Post-touch recovery
    task.wait(math.random(50, 120) / 1000)
    
    self.State.LastTouch = tick()
end

-- CRITICAL: Fire touch ke UI elements (bukan VirtualInputManager)
function MobileFish:FireTouchToUI(x, y, isBegin)
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if not playerGui then return end
    
    -- Cari UI element di posisi tersebut
    for _, gui in pairs(playerGui:GetDescendants()) do
        if gui:IsA("GuiButton") or gui:IsA("TextButton") or gui:IsA("ImageButton") then
            local absPos = gui.AbsolutePosition
            local absSize = gui.AbsoluteSize
            
            -- Check if point inside button
            if x >= absPos.X and x <= absPos.X + absSize.X and
               y >= absPos.Y and y <= absPos.Y + absSize.Y then
                
                if isBegin then
                    -- Simulate InputBegan
                    pcall(function()
                        gui.BackgroundColor3 = Color3.new(0.8, 0.8, 0.8) -- Visual feedback
                    end)
                else
                    -- Simulate InputEnded + Click
                    pcall(function()
                        gui.BackgroundColor3 = Color3.new(1, 1, 1)
                        -- Trigger click event
                        for _, conn in pairs(getconnections(gui.MouseButton1Click)) do
                            conn:Fire()
                        end
                        -- Also trigger Activated for mobile
                        for _, conn in pairs(getconnections(gui.Activated)) do
                            conn:Fire()
                        end
                    end)
                end
                return true
            end
        end
    end
    
    return false
end

-- Alternative: Direct remote spam (kalau touch tidak work)
function MobileFish:SafeRemoteCall(remoteName, ...)
    -- Cari remote dengan pencarian fuzzy
    local remote = self:FindRemote(remoteName)
    if remote then
