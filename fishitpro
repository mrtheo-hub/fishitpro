-- Main Fishing Loop (24/7 Optimized)
function MobileFish:MainLoop()
    while self.Config.Enabled do
        -- Safety check
        if not self:SafetyCheck() then
            task.wait(1)
            continue
        end
        
        local delay = self:GetDelay()
        
        -- Step 1: Cast
        if not self.State.IsFishing then
            local castPos = self:GetPos(self.Config.Positions.Cast.X, self.Config.Positions.Cast.Y)
            
            -- Randomize cast position slightly
            castPos = Vector2.new(
                castPos.X + math.random(-20, 20),
                castPos.Y + math.random(-10, 10)
            )
            
            self:Touch(castPos.X, castPos.Y, 0.1)
            self.State.IsFishing = true
            
            -- Wait for line to drop (randomized)
            task.wait(delay.Cast + math.random(0, 5))
        end
        
        -- Step 2: Wait for bite (with backup timer)
        local biteStart = tick()
        local biteDetected = false
        local detectionMethod = ""
        
        while tick() - biteStart < self.Config.Detection.BackupTimer do
            if not self.Config.Enabled then break end
            
            local detected, method = self:DetectBite()
            if detected then
                -- Human reaction time
                task.wait(delay.Reaction + (math.random(-50, 100) / 1000))
                biteDetected = true
                detectionMethod = method
                break
            end
            
            task.wait(0.1)  -- Poll rate
        end
        
        -- Step 3: Reel
        if biteDetected then
            print("🐟 Bite detected via", detectionMethod)
            
            local reelStart = tick()
            local maxReelTime = math.random(3, 6)
            
            while tick() - reelStart < maxReelTime do
                if not self.Config.Enabled then break end
                
                -- Multi-touch untuk mobile (cepat tapi natural)
                if math.random() > 0.3 then
                    self:MultiTouchReel()
                else
                    -- Single touch biasa
                    local reelX = math.random(
                        self.Config.Positions.Reel.X1 * 100,
                        self.Config.Positions.Reel.X2 * 100
                    ) / 100
                    local reelY = math.random(
                        self.Config.Positions.Reel.Y1 * 100,
                        self.Config.Positions.Reel.Y2 * 100
                    ) / 100
                    local pos = self:GetPos(reelX, reelY)
                    self:Touch(pos.X, pos.Y)
                end
                
                -- Check if still biting
                if tick() - reelStart > 1.5 then
                    local stillBiting, _ = self:DetectBite()
                    if not stillBiting then
                        -- Wait confirmation
                        task.wait(0.5)
                        local confirm, _ = self:DetectBite()
                        if not confirm then
                            break  -- Fish caught or escaped
                        end
                    end
                end
                
                -- Variable delay (anti-pattern)
                task.wait(math.random(delay.Min * 100, delay.Max * 100) / 100)
            end
            
            -- Success
            self.State.FishCount += 1
            self.Stats.TotalFish += 1
            self.State.ConsecutiveErrors = 0
            
            -- Random celebration pause (kadang-kadang)
            if math.random() > 0.7 then
                task.wait(math.random(1, 3))
            end
            
        else
            -- Timeout or error
            self.State.ConsecutiveErrors += 1
            print("⚠️ No bite detected, recasting...")
        end
        
        -- Reset state
        self.State.IsFishing = false
        
        -- Break antara cast (sangat penting!)
        task.wait(math.random(1, 3))
    end
end

-- Auto Reconnect (for 24/7)
function MobileFish:StartAutoReconnect()
    task.spawn(function()
        while self.Config.AutoReconnect do
            task.wait(30)  -- Check every 30 seconds
            
            if not self.Config.Enabled then continue end
            
            -- Check if disconnected
            if not game:IsLoaded() or not LocalPlayer.Parent then
                print("🔌 Disconnected! Attempting reconnect...")
                self.State.CrashCount += 1
                
                -- Wait for auto-rejoin atau force rejoin
                task.wait(10)
                
                -- Teleport service rejoin
                local success = pcall(function()
                    local placeId = game.PlaceId
                    local jobId = game.JobId
                    game:GetService("TeleportService"):TeleportToPlaceInstance(placeId, jobId)
                end)
                
                if not success then
                    -- Fallback: just teleport to place
                    pcall(function()
                        game:GetService("TeleportService"):Teleport(game.PlaceId)
                    end)
                end
            end
        end
    end)
end

