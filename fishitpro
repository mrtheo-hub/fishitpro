-- Main loop
function Fish:Loop()
    while Fish.Config.Enabled do
        -- Cast
        if not Fish.State.Running then
            print(">>> CASTING")
            Fish:Click(Fish.State.CastBtn)
            Fish.State.Running = true
            task.wait(2.5)
        end
        
        -- Wait bite
        local startTime = tick()
        local bite = false
        
        while tick() - startTime < 12 do
            if Fish:CheckBite() then
                bite = true
