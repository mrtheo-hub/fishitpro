-- Safety Check (CRITICAL for 24/7)
function MobileFish:SafetyCheck()
    local now = tick()
    local runtime = now - self.State.SessionStart
    local totalRuntime = now - self.Stats.StartTime
    
    -- Check session limit (4 jam)
    if runtime > self.Config.SessionLimit then
        print("⏰ Session limit reached. Taking long break...")
        self:Notify("Long Break", "30 menit istirahat biar gak ban")
        
        self.State.Sessions += 1
        self.State.SessionStart = now
        
        -- Long break
        for i = self.Config.LongBreak, 1, -1 do
            if not self.Config.Enabled then break end
            if i % 60 == 0 then
                print("Break remaining:", math.floor(i/60), "min")
            end
            task.wait(1)
        end
        
        return true
    end
    
    -- Random "sleep" (human behavior)
    if self.Config.RandomStop and math.random(1, 100) <= self.Config.StopChance then
        local sleepTime = math.random(300, 900)  -- 5-15 menit
        print("😴 Random sleep for", math.floor(sleepTime/60), "minutes")
        self:Notify("Sleep Mode", "Istirahat " .. math.floor(sleepTime/60) .. " menit")
        task.wait(sleepTime)
        return true
    end
    
    -- Check death/kick
    if self.Config.PauseOnDeath then
        local char = LocalPlayer.Character
        if char then
            local humanoid = char:FindFirstChild("Humanoid")
            if humanoid and humanoid.Health <= 0 then
                self.State.DeathCount += 1
                print("💀 Died! Waiting for respawn...")
                task.wait(5)
                return false
            end
        end
    end
    
    -- Check error threshold
    if self.State.ConsecutiveErrors > 10 then
        print("⚠️ Too many errors, restarting...")
        self.State.ConsecutiveErrors = 0
        task.wait(10)
    end
    
    return true
end

