end

-- Coba trigger dengan property change (eksperimental)
function AssistFish:TryTrigger(guiObject)
    if not guiObject then return false end
    
    -- Method 1: Coba set Active property (kadang trigger event)
    pcall(function()
        local old = guiObject.Active
        guiObject.Active = not old
        task.wait(0.01)
        guiObject.Active = old
    end)
    
    -- Method 2: Coba simulate Selection (untuk GUI navigation)
    pcall(function()
        guiObject:CaptureFocus()
        task.wait(0.01)
        guiObject:ReleaseFocus()
    end)
    
    return true
end

-- Main Loop
function AssistFish:MainLoop()
    local ui = self:ScanUI()
    
    while self.Config.Enabled do
        -- Step 1: Tunggu cast
        if not self.State.IsFishing then
            -- Tunggu user cast manual, atau coba trigger
            if self.Config.AutoReel and ui and ui.CastButton then
                -- Coba trigger (tidak garanti work)
                self:TryTrigger(ui.CastButton)
            end
            
            self.State.LastCastTime = tick()
            self.State.IsFishing = true
            self.State.BiteDetected = false
            
            -- Tunggu line settle
            task.wait(self.Config.CastDelay)
        end
        
        -- Step 2: Detect bite
        local biteStart = tick()
        local detected = false
        
        while (tick() - biteStart) < 12 do
            if not self.Config.Enabled then break end
            
            -- Rescan UI tiap 0.5 detik (UI bisa berubah)
            if math.floor(tick()) % 1 == 0 then
                ui = self:ScanUI()
            end
            
            local isBite, method = self:CheckBite(ui)
            
            if isBite and not self.State.BiteDetected then
                self.State.BiteDetected = true
                detected = true
                print("🐟 BITE DETECTED via", method)
                
                -- Alert user
                if self.Config.BeepOnBite then
                    self:Alert()
                end
                
                -- Coba auto-reel (kalau enable dan ada button)
                if self.Config.AutoReel and ui and ui.ReelButton then
                    task.wait(self.Config.ReactionDelay)
                    
                    -- Coba trigger reel berkali-kali
                    for i = 1, 10 do
                        self:TryTrigger(ui.ReelButton)
                        task.wait(0.1)
                        
                        -- Check masih biting?
                        ui = self:ScanUI()
                        if not self:CheckBite(ui) then
                            break
                        end
                    end
                end
                
                break
            end
            
            task.wait(0.1)
        end
        
        -- Step 3: Reset
        if detected then
            self.State.FishCount = self.State.FishCount + 1
            
            -- Check limit
            if self.State.FishCount >= self.Config.AutoStopAfter then
                print("🛑 Limit reached")
                self:Alert()
                self:Stop()
                break
            end
            
            task.wait(1)
        end
        
        self.State.IsFishing = false
        task.wait(0.5)
    end
end

