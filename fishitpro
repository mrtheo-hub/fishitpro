-- Detect bite (multiple methods)
function MobileFish:DetectBite()
    local confidence = 0
    
    -- Method 1: UI Text/Visibility
    if self.BiteIndicator and self.BiteIndicator.Gui then
        local gui = self.BiteIndicator.Gui
        if gui.Visible then
            if gui:IsA("TextLabel") and gui.Text ~= "" then
                confidence = confidence + 50
            elseif gui:IsA("ImageLabel") then
                confidence = confidence + 40
            end
        end
    end
    
    -- Method 2: Cari semua UI yang muncul tiba-tiba
    local playerGui = LocalPlayer:FindFirstChild("PlayerGui")
    if playerGui then
        for _, gui in pairs(playerGui:GetDescendants()) do
            if gui:IsA("TextLabel") and gui.Visible and gui.Text ~= "" then
                local text = gui.Text:lower()
                if text:find("!") or text:find("bite") or text:find("now") or text:find("pull") then
                    -- Check if it's new (wasn't visible before)
                    confidence = confidence + 30
                end
            end
        end
    end
    
    -- Method 3: Timer backup (force after 10s)
    if self.State.IsFishing and (tick() - self.State.LastTouch) > 10 then
        confidence = confidence + 20
    end
    
    return confidence >= 40, confidence
end

-- Safety checks
function MobileFish:CheckSafety()
    -- Fish limit
    if self.State.FishCount >= self.Config.MaxFishPerSession then
        print("🛑 Fish limit reached:", self.State.FishCount)
        self:Notify("Limit", "30 fish reached - stopping")
        self:Stop()
        return false
    end
    
    -- Time limit
    local elapsed = (tick() - self.State.SessionStart) / 60
    if elapsed >= self.Config.SessionMinutes then
        print("🛑 Time limit reached")
        self:Stop()
        return false
    end
    
    -- Break tiap 10 fish
    if self.State.FishCount > 0 and self.State.FishCount % self.Config.BreakAfterFish == 0 then
        if self.State.BreakCount ~= math.floor(self.State.FishCount / self.Config.BreakAfterFish) then
            self.State.BreakCount = math.floor(self.State.FishCount / self.Config.BreakAfterFish)
            print("☕ Break time:", self.Config.BreakDuration, "seconds")
            self:Notify("Break", "Resting " .. self.Config.BreakDuration .. "s")
            task.wait(self.Config.BreakDuration)
        end
    end
    
    return true
end

-- Main fishing loop
function MobileFish:FishingLoop()
    while self.Config.Enabled do
        if not self:CheckSafety() then break end
        
        local delay = self:GetDelay()
        
        -- Step 1: Cast
        if not self.State.IsFishing then
            print("🎣 Casting...")
            
            -- Random position dalam button area
            local castX = self.CastButton.X + math.random(-20, 20)
            local castY = self.CastButton.Y + math.random(-10, 10)
            
            -- Pre-cast wait
            task.wait(self:RandomDelay(0.5, 0.3))
            
            -- Touch cast button
            self:Touch(castX, castY, math.random(100, 200))
            
            self.State.IsFishing = true
            
            -- Wait for line to settle
            task.wait(self:RandomDelay(2.5, 1.5))
        end
        
        -- Step 2: Wait for bite
        local biteStart = tick()
        local biteDetected = false
        
        while (tick() - biteStart) < 12 do
            local isBite, confidence = self:DetectBite()
            
            if isBite then
                -- Reaction delay (HUMAN-LIKE!)
                local reaction = self:RandomDelay(delay.Reaction, 0.15)
                task.wait(reaction)
                
                biteDetected = true
                print("🐟 Bite! Confidence:", confidence)
                break
            end
            
            task.wait(0.1)
        end
        
        -- Step 3: Reel
        if biteDetected then
            local reelStart = tick()
            local reelCount = 0
            
            while (tick() - reelStart) < 6 do
                -- Random position dalam reel area
                local reelX = math.random(self.ReelArea.X1 + 50, self.ReelArea.X2 - 50)
                local reelY = math.random(self.ReelArea.Y1 + 50, self.ReelArea.Y2 - 50)
                
                -- Variable hold
                local hold = math.random(self.Config.HoldMin, self.Config.HoldMax)
                
                -- Touch reel area
                self:Touch(reelX, reelY, hold)
                reelCount = reelCount + 1
                
                -- Check if still biting (after few reels)
                if reelCount > 3 then
                    local stillBite, _ = self:DetectBite()
                    if not stillBite then
                        task.wait(0.5)
                        local confirm, _ = self:DetectBite()
                        if not confirm then
                            print("✓ Caught!")
                            break
                        end
                    end
                end
                
                -- Delay antar reel (CRITICAL!)
                task.wait(self:RandomDelay(delay.Base, delay.Var))
            end
            
            self.State.FishCount = self.State.FishCount + 1
            self.State.IsFishing = false
            
            -- Post-catch pause
            task.wait(self:RandomDelay(1.0, 0.5))
            
        else
            -- Timeout
            print("⚠ Timeout")
            self.State.IsFishing = false
            task.wait(2)
        end
        
        -- Random micro-break
        if math.random(1, 15) == 1 then
            print("😴 Micro break")
            task.wait(math.random(3, 8))
        end
    end
end

